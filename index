<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>エアロバイク走行＆ルーティングアプリ</title>
  <!-- LeafletおよびLeaflet Routing MachineのCSS -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.css" />
  <style>
    /* 全体のモダンなデザイン */
    body {
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      background-color: #f4f6f8;
      margin: 0;
      padding: 20px;
      color: #333;
    }
    h1 { color: #333; }
    #map {
      height: 400px;
      border: 1px solid #ccc;
      border-radius: 8px;
      margin-bottom: 10px;
    }
    .controls { margin-bottom: 10px; }
    button {
      background-color: #007bff;
      border: none;
      border-radius: 4px;
      color: #fff;
      padding: 8px 12px;
      margin-right: 5px;
      cursor: pointer;
    }
    button:hover { background-color: #0056b3; }
    
    /* 進捗マーカーのデザイン：モダンでアニメーション効果あり */
    .progress-marker {
      width: 20px;
      height: 20px;
      background: #ff5722;
      border-radius: 50%;
      border: 3px solid #fff;
      box-shadow: 0 0 8px rgba(255,87,34,0.6);
      transition: transform 0.5s ease;
    }
    /* Google Maps リンク表示エリア */
    #gmapsLinkContainer {
      margin-top: 20px;
      text-align: center;
    }
    #gmapsLink {
      display: inline-block;
      background-color: #28a745;
      color: #fff;
      text-decoration: none;
      padding: 10px 16px;
      border-radius: 4px;
    }
    #gmapsLink:hover { background-color: #218838; }
  </style>
</head>
<body>
  <h1>エアロバイク走行＆ルーティングアプリ</h1>
  <p>
    ダブルクリックで出発地点と目的地点を指定してください。<br>
    ※最初のダブルクリックで出発地点、次のダブルクリックで目的地を設定します。
  </p>
  
  <!-- 地図表示エリア -->
  <div id="map"></div>
  <div class="controls">
    <button id="resetRouteBtn">ルートリセット</button>
  </div>
  
  <!-- 累積走行距離入力フォーム -->
  <form id="distanceForm">
    <fieldset>
      <legend>走行距離更新</legend>
      <label for="distance">本日の走行距離（km）:</label>
      <input type="number" id="distance" step="0.1" required>
      <button type="submit">追加</button>
    </fieldset>
  </form>
  
  <div>
    <h2>現在の累積走行距離: <span id="totalDistance">0</span> km</h2>
  </div>
  
  <!-- 保存済みデータの管理 -->
  <div class="controls">
    <fieldset>
      <legend>保存済みデータ</legend>
      <button id="saveBtn">保存</button>
      <select id="savedSelect"></select>
      <button id="loadSelectedBtn">選択してロード</button>
      <button id="clearDataBtn">全保存データ削除</button>
      <button id="exportCsvBtn">CSV出力</button>
    </fieldset>
  </div>
  
  <!-- Google Maps リンク表示エリア -->
  <div id="gmapsLinkContainer">
    <h2>現在地（Google Mapsリンク）</h2>
    <a id="gmapsLink" href="#" target="_blank">現在地を見る</a>
  </div>
  
  <!-- 必要なライブラリの読み込み -->
  <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
  <script src="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.js"></script>
  
  <script>
    // 地図の初期化（日本限定）
    var map = L.map('map', { doubleClickZoom: false }).setView([36.2048, 138.2529], 5);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 18,
      attribution: '© OpenStreetMap'
    }).addTo(map);
    var southWest = L.latLng(24.0, 122.0);
    var northEast = L.latLng(46.0, 153.0);
    map.setMaxBounds(L.latLngBounds(southWest, northEast));
    
    // グローバル変数
    var startMarker = null, destMarker = null, routingControl = null;
    var totalDistance = 0, routeDistance = 0;
    var routeCoords = [];
    var cumulativeDistances = [];
    var progressMarker = null; // 進捗状況を示すマーカー
    
    // ロードした過去データのインデックス（ロード時にセットされ、保存時に上書き）
    var loadedIndex = null;
    
    // 保存データの配列を取得（なければ空配列）
    var savedDataList = JSON.parse(localStorage.getItem("aerobikeDataList")) || [];
    updateSavedSelect();
    
    // マップ上でのダブルクリックによる地点指定
    map.on('dblclick', function(e) {
      if (!startMarker) {
        startMarker = L.marker(e.latlng, { draggable: true }).addTo(map)
                       .bindPopup('出発地点').openPopup();
        alert("出発地点が設定されました。次に目的地をダブルクリックしてください。");
      } else if (!destMarker) {
        destMarker = L.marker(e.latlng, { draggable: true }).addTo(map)
                      .bindPopup('目的地').openPopup();
        createRoute();
      } else {
        alert("出発地点と目的地は既に設定されています。ルートリセットで再設定してください。");
      }
    });
    
    // ルート生成関数（Leaflet Routing Machineを利用）
    function createRoute() {
      if (routingControl !== null) {
        map.removeControl(routingControl);
      }
      routingControl = L.Routing.control({
        waypoints: [startMarker.getLatLng(), destMarker.getLatLng()],
        router: L.Routing.osrmv1({ serviceUrl: 'https://router.project-osrm.org/route/v1' }),
        routeWhileDragging: true,
        showAlternatives: false,
        lineOptions: { styles: [{ color: '#007bff', opacity: 0.6, weight: 5 }] },
        createMarker: function() { return null; }
      }).addTo(map);
      
      routingControl.on('routesfound', function(e) {
        var route = e.routes[0];
        routeDistance = route.summary.totalDistance / 1000; // m → km
        // ルートの座標配列を取得
        routeCoords = route.coordinates.map(function(coord) {
          return L.latLng(coord.lat, coord.lng);
        });
        // 各セグメントの累積距離を計算
        cumulativeDistances = [0];
        for (var i = 1; i < routeCoords.length; i++) {
          var dist = routeCoords[i-1].distanceTo(routeCoords[i]);
          cumulativeDistances.push(cumulativeDistances[i-1] + dist);
        }
        updateProgressMarker();
      });
    }
    
    // ルートリセット処理
    document.getElementById('resetRouteBtn').addEventListener('click', function() {
      if (startMarker) { map.removeLayer(startMarker); startMarker = null; }
      if (destMarker) { map.removeLayer(destMarker); destMarker = null; }
      if (routingControl) { map.removeControl(routingControl); routingControl = null; }
      routeDistance = 0;
      routeCoords = [];
      cumulativeDistances = [];
      if (progressMarker) { map.removeLayer(progressMarker); progressMarker = null; }
      // リンクはクリア
      document.getElementById("gmapsLink").href = "#";
      document.getElementById("gmapsLink").innerText = "現在地を見る";
      alert("ルートがリセットされました。再度ダブルクリックで出発地点を設定してください。");
      // ロード済みデータのインデックスもクリア
      loadedIndex = null;
    });
    
    // 累積走行距離更新処理（入力された本日の距離を前回の合計に加算）
    document.getElementById('distanceForm').addEventListener('submit', function(e) {
      e.preventDefault();
      var distance = parseFloat(document.getElementById('distance').value);
      if (isNaN(distance) || distance < 0) {
        alert('正しい距離を入力してください。');
        return;
      }
      totalDistance += distance;  // ← 加算して累積する
      document.getElementById('totalDistance').innerText = totalDistance.toFixed(1);
      updateProgressMarker();
      document.getElementById('distanceForm').reset();
    });
    
    // カスタムアイコン（進捗マーカー用）
    var progressIcon = L.divIcon({
      className: 'progress-marker',
      iconSize: [20, 20]
    });
    
    // 進捗マーカー更新関数：ルート上で進捗に応じた位置にマーカーを移動させる
    function updateProgressMarker() {
      if (routeDistance <= 0 || routeCoords.length === 0) return;
      var fraction = Math.min(totalDistance / routeDistance, 1);
      var newLatLng = computeLatLngAlongRoute(fraction);
      if (!newLatLng) return;
      if (!progressMarker) {
        progressMarker = L.marker(newLatLng, { icon: progressIcon, interactive: false }).addTo(map);
      } else {
        progressMarker.setLatLng(newLatLng);
      }
      // Google Maps リンク更新（クリックするとその地点に飛べる）
      updateGoogleMapLink(newLatLng);
    }
    
    // ルート上の指定された進捗率に対応する LatLng を計算する（線形補間）
    function computeLatLngAlongRoute(fraction) {
      var targetDistance = routeDistance * 1000 * fraction; // km → m
      for (var i = 1; i < cumulativeDistances.length; i++) {
        if (cumulativeDistances[i] >= targetDistance) {
          var prevDist = cumulativeDistances[i-1];
          var segmentLength = cumulativeDistances[i] - prevDist;
          var segmentFraction = (targetDistance - prevDist) / segmentLength;
          var lat1 = routeCoords[i-1].lat, lng1 = routeCoords[i-1].lng;
          var lat2 = routeCoords[i].lat, lng2 = routeCoords[i].lng;
          var lat = lat1 + (lat2 - lat1) * segmentFraction;
          var lng = lng1 + (lng2 - lng1) * segmentFraction;
          return L.latLng(lat, lng);
        }
      }
      return routeCoords[routeCoords.length - 1];
    }
    
    // Google Maps リンク更新関数
    function updateGoogleMapLink(latlng) {
      var lat = latlng.lat;
      var lng = latlng.lng;
      // Google Maps のリンク（クリックすると該当地点へ）
      var url = "https://www.google.com/maps/search/?api=1&query=" + lat + "," + lng;
      var linkElem = document.getElementById("gmapsLink");
      linkElem.href = url;
      linkElem.innerText = "Google Mapsで現在地を見る (" + lat.toFixed(5) + ", " + lng.toFixed(5) + ")";
    }
    
    // --- 保存・ロード・CSV出力機能 ---
    
    // 保存ボタンの処理：タイトル入力後、現在のデータを保存（過去データロード時は上書き保存）
    document.getElementById('saveBtn').addEventListener('click', saveData);
    function saveData() {
      var title = prompt("保存するデータのタイトルを入力してください:");
      if (!title) return;
      var dataObj = {
        title: title,
        start: startMarker ? startMarker.getLatLng() : null,
        dest: destMarker ? destMarker.getLatLng() : null,
        totalDistance: totalDistance,
        routeDistance: routeDistance,
        routeCoords: routeCoords.map(function(latlng) { return { lat: latlng.lat, lng: latlng.lng }; })
      };
      if (loadedIndex !== null) {
        // 過去データをロードしている場合は、上書き保存
        savedDataList[loadedIndex] = dataObj;
        alert("データを上書き保存しました。");
      } else {
        savedDataList.push(dataObj);
        alert("データを保存しました。");
      }
      localStorage.setItem("aerobikeDataList", JSON.stringify(savedDataList));
      updateSavedSelect();
      // 上書き保存後、loadedIndex をリセット（必要に応じて残してもよい）
      loadedIndex = null;
    }
    
    // 保存済みデータのセレクトボックス更新関数
    function updateSavedSelect() {
      var select = document.getElementById("savedSelect");
      select.innerHTML = "";
      var defaultOption = document.createElement("option");
      defaultOption.value = "";
      defaultOption.text = "--選択してください--";
      select.appendChild(defaultOption);
      savedDataList.forEach(function(item, index) {
        var option = document.createElement("option");
        option.value = index;
        option.text = item.title;
        select.appendChild(option);
      });
    }
    
    // ロードボタンの処理：選択された保存データを読み込み、マーカー・ルート・走行距離を復元し、loadedIndex を設定
    document.getElementById('loadSelectedBtn').addEventListener('click', function(){
      var select = document.getElementById('savedSelect');
      var index = select.value;
      if(index === "") { alert("保存されたデータが選択されていません。"); return; }
      var data = savedDataList[index];
      if(startMarker) { map.removeLayer(startMarker); startMarker = null; }
      if(destMarker) { map.removeLayer(destMarker); destMarker = null; }
      if(routingControl) { map.removeControl(routingControl); routingControl = null; }
      if(progressMarker) { map.removeLayer(progressMarker); progressMarker = null; }
      if(data.start) {
        startMarker = L.marker(data.start, { draggable: true }).addTo(map)
                       .bindPopup('出発地点').openPopup();
      }
      if(data.dest) {
        destMarker = L.marker(data.dest, { draggable: true }).addTo(map)
                       .bindPopup('目的地').openPopup();
      }
      if(data.start && data.dest) {
        createRoute();
      }
      totalDistance = parseFloat(data.totalDistance) || 0;
      document.getElementById('totalDistance').innerText = totalDistance.toFixed(1);
      updateProgressMarker();
      // 記憶したインデックスをグローバル変数にセット
      loadedIndex = parseInt(index);
      alert("データをロードしました。（このデータは上書き保存可能です）");
    });
    
    // 全保存データ削除ボタンの処理
    document.getElementById('clearDataBtn').addEventListener('click', function(){
      if(confirm("全ての保存データを削除してよろしいですか？")){
        savedDataList = [];
        localStorage.removeItem("aerobikeDataList");
        updateSavedSelect();
        alert("保存データを削除しました。");
      }
    });
    
    // CSV出力ボタンの処理：保存済みデータをCSV形式に変換してダウンロード
    document.getElementById('exportCsvBtn').addEventListener('click', exportToCsv);
    function exportToCsv() {
      if (savedDataList.length === 0) {
        alert("保存されたデータがありません。");
        return;
      }
      var csvContent = "data:text/csv;charset=utf-8,";
      csvContent += "Title,StartLat,StartLng,DestLat,DestLng,TotalDistance,RouteDistance\n";
      savedDataList.forEach(function(item) {
        var row = [
          item.title,
          item.start ? item.start.lat : "",
          item.start ? item.start.lng : "",
          item.dest ? item.dest.lat : "",
          item.dest ? item.dest.lng : "",
          item.totalDistance,
          item.routeDistance
        ].join(",");
        csvContent += row + "\n";
      });
      var encodedUri = encodeURI(csvContent);
      var link = document.createElement("a");
      link.setAttribute("href", encodedUri);
      link.setAttribute("download", "aerobike_data.csv");
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    }
  </script>
</body>
</html>
